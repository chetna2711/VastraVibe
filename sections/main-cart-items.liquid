{{ 'component-cart.css' | asset_url | stylesheet_tag }}
{{ 'component-cart-items.css' | asset_url | stylesheet_tag }}
{{ 'component-totals.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}
{{ 'component-discounts.css' | asset_url | stylesheet_tag }}
{{ 'quantity-popover.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{%- unless settings.cart_type == 'drawer' -%}
  <script src="{{ 'cart.js' | asset_url }}" defer="defer"></script>
{%- endunless -%}

<script src="{{ 'quantity-popover.js' | asset_url }}" defer="defer"></script>

{{ 'custom-cart.css' | asset_url | stylesheet_tag }}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>

<cart-items class="gradient color-{{ section.settings.color_scheme }} isolate{% if cart == empty %} is-empty{% else %} section-{{ section.id }}-padding{% endif %}">
  <div class="page-width">
    <!-- Redesigned Header -->
    <div class="cart-header-section">
      <div class="cart-breadcrumb">
        <a href="{{ routes.root_url }}">Home</a>
        <span>•</span>
        <span>Your Shopping Cart</span>
      </div>
      <h1 class="title title--primary">Shopping Cart</h1>
      <p class="subtitle">Review your selected items before purchase. Enjoy a seamless shopping experience!</p>
      
      <div class="limited-time-alert">
         {{- 'icon-fire.svg' | inline_asset_content -}}
         <span class="alert-text">Products are limited, checkout within <span id="cart-countdown" class="countdown">02 m 00 s</span></span>
      </div>
    </div>

    <div class="cart__warnings">
      <h1 class="cart__empty-text">{{ 'sections.cart.empty' | t }}</h1>
      <a href="{{ routes.all_products_collection_url }}" class="button">
        {{ 'general.continue_shopping' | t }}
      </a>

      {%- if shop.customer_accounts_enabled and customer == null -%}
        <h2 class="cart__login-title">{{ 'sections.cart.login.title' | t }}</h2>
        <p class="cart__login-paragraph">
          {{ 'sections.cart.login.paragraph_html' | t: link: routes.account_login_url }}
        </p>
      {%- endif -%}
    </div>

    <form action="{{ routes.cart_url }}" class="cart__contents critical-hidden" method="post" id="cart">
      <div class="cart__items" id="main-cart-items" data-id="{{ section.id }}">
        <div class="js-contents">
          {%- if cart != empty -%}
            <table class="cart-items">
              <thead>
                <tr>
                  <th scope="col">Product</th>
                  <th class="small-hide" scope="col">Price</th>
                  <th class="right" scope="col">Total</th>
                </tr>
              </thead>
              <tbody>
                {%- for item in cart.items -%}
                  <tr class="cart-item" id="CartItem-{{ item.index | plus: 1 }}">
                    <td class="cart-item__media-details">
                      <div class="cart-item__media">
                        <a href="{{ item.url }}" class="cart-item__link">
                          <img
                            src="{{ item.image | image_url: width: 300 }}"
                            alt="{{ item.image.alt | escape }}"
                            loading="lazy"
                            width="140"
                            height="{{ 140 | divided_by: item.image.aspect_ratio | ceil }}"
                            style="border-radius: 8px;"
                          >
                        </a>
                      </div>
                      <div class="cart-item__details">
                        <a href="{{ item.url }}" class="cart-item__name h4">{{ item.product.title | escape }}</a>
                        {%- if item.product.has_only_default_variant == false -%}
                          {%- for option in item.options_with_values -%}
                            <p class="product-option" style="margin: 0; color: #666; font-size: 14px;">{{ option.name }}: {{ option.value }}</p>
                          {%- endfor -%}
                        {%- endif -%}
                        <div class="cart-item__total-mobile-price medium-hide large-up-hide">
                          {{ item.original_line_price | money }}
                        </div>
                        <cart-remove-button id="Remove-{{ item.index | plus: 1 }}" data-index="{{ item.index | plus: 1 }}">
                          <a href="{{ item.url_to_remove }}" class="cart-item__remove-link">Remove</a>
                        </cart-remove-button>
                      </div>
                    </td>
                    <td class="cart-item__price-unit small-hide">
                      {{ item.original_price | money }}
                    </td>
                    <td class="cart-item__total-price right">
                      {{ item.original_line_price | money }}
                    </td>
                  </tr>
                {%- endfor -%}
              </tbody>
            </table>
          {%- endif -%}
        </div>
      </div>
      
      <!-- Trust Badges (Positioned after table) -->
      <div class="trust-badges">
        <div class="trust-badge-item">
          <div class="icon">{{- 'icon-chat-bubble.svg' | inline_asset_content -}}</div>
          <h3>Have Questions?</h3>
          <p>Our experts are here to help! Call us free.</p>
        </div>
        <div class="trust-badge-item">
          <div class="icon">{{- 'icon-lock.svg' | inline_asset_content -}}</div>
          <h3>Secure Shopping</h3>
          <p>All transactions are protected by SSL technology.</p>
        </div>
        <div class="trust-badge-item">
           <div class="icon">{{- 'icon-checkmark.svg' | inline_asset_content -}}</div>
          <h3>Privacy Protection</h3>
          <p>Your privacy is always our top priority.</p>
        </div>
      </div>

      <!-- You Might Also Like Slider -->
      <div class="cart-recommendations">
        <h2>You may also like...</h2>
        <div class="cart-recommendations-slider swiper" style="padding-bottom: 40px;">
          {%- if cart.items.size > 0 -%}
            {%- assign first_item_id = cart.items[0].product_id -%}
            <product-recommendations class="swiper-wrapper" data-url="{{ routes.product_recommendations_url }}?section_id={{ section.id }}&product_id={{ first_item_id }}&limit=10">
              {%- if recommendations.performed and recommendations.products_count > 0 -%}
                {%- for recommendation in recommendations.products -%}
                  <div class="swiper-slide">
                    <div class="recommendation-card">
                      <div class="recommendation-card__image">
                        <img src="{{ recommendation.featured_image | image_url: width: 300 }}" alt="{{ recommendation.title }}">
                      </div>
                      <div class="recommendation-card__info">
                        <h3 class="recommendation-card__title">{{ recommendation.title }}</h3>
                        <div class="recommendation-card__price">
                          {%- if recommendation.compare_at_price > recommendation.price -%}
                            <span class="sale-price" style="color: #7a2b3d; font-weight: bold;">{{ recommendation.price | money }}</span>
                            <span class="regular-price" style="text-decoration: line-through; color: #999; font-size: 0.9em;">{{ recommendation.compare_at_price | money }}</span>
                          {%- else -%}
                            <span class="price">{{ recommendation.price | money }}</span>
                          {%- endif -%}
                        </div>
                        <button type="button" class="recommendation-card__add" onclick="addRecommendationToCart({{ recommendation.variants.first.id }}, this)">Add To Cart</button>
                      </div>
                    </div>
                  </div>
                {%- endfor -%}
              {%- else -%}
                {%- for product in collections.all.products limit: 10 -%}
                  <div class="swiper-slide">
                    <div class="recommendation-card">
                      <div class="recommendation-card__image">
                        <img src="{{ product.featured_image | image_url: width: 300 }}" alt="{{ product.title }}">
                      </div>
                      <div class="recommendation-card__info">
                        <h3 class="recommendation-card__title">{{ product.title }}</h3>
                        <div class="recommendation-card__price">
                           {%- if product.compare_at_price > product.price -%}
                            <span class="sale-price" style="color: #7a2b3d; font-weight: bold;">{{ product.price | money }}</span>
                            <span class="regular-price" style="text-decoration: line-through; color: #999; font-size: 0.9em;">{{ product.compare_at_price | money }}</span>
                          {%- else -%}
                            <span class="price">{{ product.price | money }}</span>
                          {%- endif -%}
                        </div>
                        <button type="button" class="recommendation-card__add" onclick="addRecommendationToCart({{ product.variants.first.id }}, this)">Add To Cart</button>
                      </div>
                    </div>
                  </div>
                {%- endfor -%}
              {%- endif -%}
            </product-recommendations>
          {%- endif -%}
          <!-- Pagination -->
          <div class="swiper-pagination"></div>
        </div>
      </div>

      <p class="visually-hidden" id="cart-live-region-text" aria-live="polite" role="status"></p>
      <p
        class="visually-hidden"
        id="shopping-cart-line-item-status"
        aria-live="polite"
        aria-hidden="true"
        role="status"
      >
        {{ 'accessibility.loading' | t }}
      </p>
    </form>
  </div>
</cart-items>

<script>
  // Countdown Timer
  function startTimer(duration, display) {
    var timer = duration, minutes, seconds;
    var interval = setInterval(function () {
        minutes = parseInt(timer / 60, 10);
        seconds = parseInt(timer % 60, 10);

        minutes = minutes < 10 ? "0" + minutes : minutes;
        seconds = seconds < 10 ? "0" + seconds : seconds;

        display.textContent = minutes + " m " + seconds + " s";

        if (--timer < 0) {
            timer = duration; // Reset for demo
        }
    }, 1000);
  }

  function addRecommendationToCart(variantId, button) {
    button.textContent = 'Adding...';
    button.disabled = true;

    let formData = {
     'items': [{
      'id': variantId,
      'quantity': 1
      }]
    };

    fetch(window.Shopify.routes.root + 'cart/add.js', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json'
      },
      body: JSON.stringify(formData)
    })
    .then(response => {
      return response.json();
    })
    .then(response => {
      // Refresh cart sections
      if (document.querySelector('cart-items')) {
        document.querySelector('cart-items').onCartUpdate();
      }
      button.textContent = 'Added!';
      setTimeout(() => {
        button.textContent = 'Add To Cart';
        button.disabled = false;
      }, 2000);
    })
    .catch((error) => {
      console.error('Error:', error);
      button.textContent = 'Add To Cart';
      button.disabled = false;
    });
  }

  function initRecommendationsSlider() {
    const sliderSelector = '.cart-recommendations-slider';
    const sliderElement = document.querySelector(sliderSelector);
    if (!sliderElement) return;

    // Destroy existing instance if it exists
    if (sliderElement.swiper) {
      sliderElement.swiper.destroy(true, true);
    }

    new Swiper(sliderSelector, {
      slidesPerView: 1,
      spaceBetween: 20,
      grabCursor: true,
      pagination: {
        el: '.swiper-pagination',
        clickable: true,
      },
      breakpoints: {
        // when window width is >= 750px (tablet)
        750: {
          slidesPerView: 2,
          spaceBetween: 20
        },
        // when window width is >= 1200px (desktop)
        1200: {
          slidesPerView: 3,
          spaceBetween: 30
        }
      }
    });
  }

  // Initialize on load
  window.addEventListener('load', function () {
    var timeLimit = 60 * 10, // 10 minutes
        display = document.querySelector('#cart-countdown');
    if(display) startTimer(timeLimit, display);
    
    initRecommendationsSlider();

    // Re-init when Dawn updates sections using MutationObserver
    const cartItems = document.querySelector('cart-items');
    if (cartItems) {
      const observer = new MutationObserver((mutations) => {
        mutations.forEach((mutation) => {
          if (mutation.type === 'childList') {
            initRecommendationsSlider();
          }
        });
      });
      observer.observe(cartItems, { childList: true });
    }
  });

  // Basic Fetch for Recommendations if needed
  if (!customElements.get('product-recommendations')) {
    class ProductRecommendations extends HTMLElement {
      constructor() {
        super();
        const observer = new IntersectionObserver((entries, observer) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              fetch(this.dataset.url)
                .then(response => response.text())
                .then(text => {
                  const html = new DOMParser().parseFromString(text, 'text/html');
                  const recommendations = html.querySelector('product-recommendations');
                  if (recommendations && recommendations.innerHTML.trim().length) {
                    this.innerHTML = recommendations.innerHTML;
                    // Re-init swiper after content load
                    setTimeout(initRecommendationsSlider, 200);
                  }
                })
                .catch(e => {
                  console.error(e);
                });
              observer.unobserve(this);
            }
          });
        }, {rootMargin: '0px 0px 200px 0px'});

        observer.observe(this);
      }
    }
    customElements.define('product-recommendations', ProductRecommendations);
  }
</script>


{% schema %}
{
  "name": "t:sections.main-cart-items.name",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ]
}
{% endschema %}

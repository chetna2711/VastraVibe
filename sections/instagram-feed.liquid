<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .instagram-feed {
    background-color: {{ section.settings.bg_color }};
  }

  .instagram-feed__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 3rem;
  }

  .instagram-feed__title-group {
    max-width: 70%;
  }

  .instagram-feed__title {
    margin: 0 0 1rem;
    font-size: 3.2rem;
    font-weight: 600;
  }

  .instagram-feed__description {
    margin: 0;
    font-size: 1.6rem;
    color: rgba(var(--color-foreground), 0.7);
  }

  .instagram-feed__follow-link {
    font-size: 1.6rem;
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 0.5rem;
    color: currentColor;
    white-space: nowrap;
  }

  .instagram-feed__slider-wrapper {
    position: relative;
    overflow: visible !important;
  }

  .instagram-feed .swiper {
    width: 100%;
    position: relative;
    overflow: hidden; /* Keep swiper container itself hidden */
  }

  .instagram-feed__item {
    position: relative;
    aspect-ratio: 4 / 5; /* Taller portrait aspect ratio */
    overflow: hidden;
    border-radius: 15px; /* Increased for rounded look */
    background: #f4f4f4;
    display: block;
  }

  .instagram-feed__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }

  .instagram-feed__overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: transparent; /* Cleaner look like screenshot */
    opacity: 0;
    transition: opacity 0.3s ease;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .instagram-feed__item:hover .instagram-feed__overlay {
    opacity: 1;
  }
  
  .instagram-feed__item:hover .instagram-feed__image {
    transform: scale(1.05); /* Subtle zoom on hover */
  }

  .instagram-feed__icon {
    width: 4.5rem;
    height: 4.5rem;
    background: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 15px rgba(0,0,0,0.15); /* Stronger shadow for visibility without overlay */
    z-index: 3;
    padding: 1.2rem;
    box-sizing: border-box;
    transition: transform 0.3s ease;
  }

  .instagram-feed__item:hover .instagram-feed__icon {
    transform: scale(1.1);
  }

  .instagram-feed__icon svg {
    display: block;
    width: 100%;
    height: 100%;
    fill: #000;
  }

  /* Navigation */
  .instagram-feed .swiper-button-prev,
  .instagram-feed .swiper-button-next {
    background: white;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    box-shadow: 0 4px 10px rgba(0,0,0,0.1);
    color: black;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    margin: 0;
  }

  .instagram-feed .swiper-button-next::after,
  .instagram-feed .swiper-button-prev::after {
    font-size: 1.8rem;
    font-weight: bold;
  }

  .instagram-feed .swiper-button-prev { left: -22px; }
  .instagram-feed .swiper-button-next { right: -22px; }

  @media screen and (max-width: 1100px) {
    .instagram-feed .swiper-button-prev { left: 10px; }
    .instagram-feed .swiper-button-next { right: 10px; }
  }

  @media screen and (max-width: 749px) {
    .instagram-feed__header {
      flex-direction: column;
      align-items: flex-start;
      gap: 1.5rem;
    }
    .instagram-feed__title-group {
      max-width: 100%;
    }
    .instagram-feed__title {
      font-size: 2.4rem;
    }
  }
{%- endstyle -%}

<div class="instagram-feed section-{{ section.id }}-padding">
  <div class="page-width">
    <div class="instagram-feed__header">
      <div class="instagram-feed__title-group">
        {%- if section.settings.heading != blank -%}
          <h2 class="instagram-feed__title">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.description != blank -%}
          <p class="instagram-feed__description">{{ section.settings.description }}</p>
        {%- endif -%}
      </div>
      {%- if section.settings.follow_url != blank -%}
        <a href="{{ section.settings.follow_url }}" class="instagram-feed__follow-link" target="_blank">
          {{ section.settings.follow_label }}
        </a>
      {%- endif -%}
    </div>

      <div class="instagram-feed__slider-wrapper">
        <div class="swiper swiper-{{ section.id }}">
          <div class="swiper-wrapper">
            {%- for block in section.blocks -%}
              <div class="swiper-slide" {{ block.shopify_attributes }}>
                <a href="{{ block.settings.post_url | default: '#' }}" class="instagram-feed__item" target="_blank">
                  {%- if block.settings.image != blank -%}
                    <img src="{{ block.settings.image | image_url: width: 600 }}" alt="Instagram Image" class="instagram-feed__image" loading="lazy">
                  {%- else -%}
                    {{ 'image' | placeholder_svg_tag: 'instagram-feed__image placeholder-svg' }}
                  {%- endif -%}
                  
                  <div class="instagram-feed__overlay">
                    <div class="instagram-feed__icon">
                      <svg viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 1.366.062 2.633.332 3.608 1.308.975.975 1.245 2.242 1.308 3.607.058 1.266.07 1.646.07 4.85s-.012 3.584-.07 4.85c-.063 1.366-.333 2.633-1.308 3.608-.975.975-2.242 1.245-3.608 1.308-1.266.058-1.646.07-4.85.07s-3.584-.012-4.85-.07c-1.366-.063-2.633-.333-3.608-1.308-.975-.975-1.245-2.242-1.308-3.608-.058-1.266-.07-1.646-.07-4.85s.012-3.584.07-4.85c.062-1.366.332-2.633 1.308-3.608.975-.975 2.242-1.245 3.607-1.308 1.266-.058 1.646-.07 4.85-.07zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.28.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.668-.072-4.948-.197-4.359-2.62-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
                    </div>
                  </div>
                </a>
              </div>
            {%- endfor -%}
          </div>
        </div>

        {%- if section.settings.show_arrows -%}
          <div class="swiper-button-prev swiper-button-prev-{{ section.id }}"></div>
          <div class="swiper-button-next swiper-button-next-{{ section.id }}"></div>
        {%- endif -%}

        {%- if section.settings.show_pagination -%}
          <div class="swiper-pagination swiper-pagination-{{ section.id }}"></div>
        {%- endif -%}
      </div>
  </div>
</div>

<script>
  function initInstagramSwiper{{ section.id | replace: '-', '_' }}() {
    const container = document.querySelector('.swiper-{{ section.id }}');
    if (!container) return;

    if (container.swiper) container.swiper.destroy(true, true);

    const isMarquee = {{ section.settings.enable_marquee }};
    const showHoverPause = {{ section.settings.pause_on_hover }};
    
    const swiper = new Swiper(container, {
      freeMode: true,
      slidesPerView: {{ section.settings.mobile_slides }},
      spaceBetween: 20,
      loop: {{ section.settings.enable_loop }},
      speed: isMarquee ? 5000 : 300,
      observer: true,
      observeParents: true,
      watchSlidesProgress: true,
      {% if section.settings.enable_autoplay or section.settings.enable_marquee %}
      autoplay: {
        delay: isMarquee ? 0 : {{ section.settings.autoplay_speed | times: 1000 }},
        disableOnInteraction: false,
      },
      {% endif %}
      navigation: {
        nextEl: '.swiper-button-next-{{ section.id }}',
        prevEl: '.swiper-button-prev-{{ section.id }}',
      },
      pagination: {
        el: '.swiper-pagination-{{ section.id }}',
        clickable: true,
      },
      breakpoints: {
        750: {
          slidesPerView: {{ section.settings.tablet_slides }},
        },
        1100: {
          slidesPerView: {{ section.settings.desktop_slides }},
        }
      },
      on: {
        init: function() {
          if(isMarquee) {
            this.el.querySelector('.swiper-wrapper').style.transitionTimingFunction = 'linear';
          }
        }
      }
    });

    if (showHoverPause) {
      container.addEventListener('mouseenter', () => {
        swiper.autoplay.stop();
        if(isMarquee) {
          const wrapper = container.querySelector('.swiper-wrapper');
          const transform = window.getComputedStyle(wrapper).getPropertyValue('transform');
          wrapper.style.transform = transform;
          wrapper.style.transitionDuration = '0ms';
        }
      });
      container.addEventListener('mouseleave', () => {
        if(isMarquee) {
           const wrapper = container.querySelector('.swiper-wrapper');
           wrapper.style.transitionDuration = '5000ms';
        }
        swiper.autoplay.start();
      });
    }
  }

  document.addEventListener('DOMContentLoaded', initInstagramSwiper{{ section.id | replace: '-', '_' }});
  
  if (Shopify.designMode) {
    document.addEventListener('shopify:section:load', (event) => {
      if (event.detail.sectionId === '{{ section.id }}') {
        initInstagramSwiper{{ section.id | replace: '-', '_' }}();
      }
    });
  }

  // Final backup for browser sync / fast refresh
  initInstagramSwiper{{ section.id | replace: '-', '_' }}();
</script>

{% schema %}
{
  "name": "Instagram Feed",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "default": "@YourInstagram",
      "label": "Heading"
    },
    {
      "type": "text",
      "id": "description",
      "default": "Inspire and let yourself be inspired, from one unique fashion to another.",
      "label": "Description"
    },
    {
      "type": "text",
      "id": "follow_label",
      "default": "Follow Us",
      "label": "Follow Us Label"
    },
    {
      "type": "url",
      "id": "follow_url",
      "label": "Follow Us Link"
    },
    {
      "type": "color",
      "id": "bg_color",
      "default": "#ffffff",
      "label": "Background Color"
    },
    {
      "type": "header",
      "content": "Slider Settings"
    },
    {
      "type": "range",
      "id": "desktop_slides",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 5,
      "label": "Slides on Desktop"
    },
    {
      "type": "range",
      "id": "tablet_slides",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3,
      "label": "Slides on Tablet"
    },
    {
      "type": "range",
      "id": "mobile_slides",
      "min": 1,
      "max": 2,
      "step": 0.1,
      "default": 1.2,
      "label": "Slides on Mobile"
    },
    {
      "type": "checkbox",
      "id": "enable_marquee",
      "default": false,
      "label": "Enable Marquee (Continuous Scroll)",
      "info": "This will make the slider scroll continuously without pausing."
    },
    {
      "type": "checkbox",
      "id": "show_arrows",
      "default": true,
      "label": "Show Slider Arrows"
    },
    {
      "type": "checkbox",
      "id": "enable_autoplay",
      "default": true,
      "label": "Enable Autoplay"
    },
    {
      "type": "checkbox",
      "id": "show_pagination",
      "default": true,
      "label": "Show Slider Dots"
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "min": 2,
      "max": 10,
      "step": 1,
      "unit": "s",
      "default": 5,
      "label": "Autoplay Speed"
    },
    {
      "type": "checkbox",
      "id": "pause_on_hover",
      "default": true,
      "label": "Pause on Hover"
    },
    {
      "type": "checkbox",
      "id": "enable_loop",
      "default": true,
      "label": "Continuous Loop"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 60,
      "label": "Padding Top"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 60,
      "label": "Padding Bottom"
    }
  ],
  "blocks": [
    {
      "type": "post",
      "name": "Instagram Post",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "url",
          "id": "post_url",
          "label": "Link to Post"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Instagram Feed",
      "blocks": [
        { "type": "post" },
        { "type": "post" },
        { "type": "post" },
        { "type": "post" },
        { "type": "post" }
      ]
    }
  ]
}
{% endschema %}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .featured-collection-slider {
    position: relative;
    overflow: hidden;
  }

  .featured-collection-slider .swiper {
    width: 100%;
    padding-bottom: 50px;
  }

  .featured-collection-slider .swiper-slide {
    height: auto;
  }

  /* Custom Product Card Overlay Style */
  .slider-product-card {
    position: relative;
    border-radius: 12px;
    overflow: hidden;
    background: #fff;
    transition: transform 0.3s ease;
    cursor: pointer;
  }

  .slider-product-card:hover {
    transform: translateY(-5px);
  }

  .slider-product-card .media {
    position: relative;
    width: 100%;
    padding-bottom: 140%; /* Increased height */
    background: #f3f3f3;
  }

  .slider-product-card img, 
  .slider-product-card video {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .slider-product-card__info-overlay {
    position: absolute;
    bottom: 12px;
    left: 10px;
    right: 10px;
    background:#808080d9;
    padding: 14px;
    border-radius: 3px;
    color: #fff;
    display: flex;
    align-items: center;
    gap: 15px;
  }

  .slider-product-card__thumb {
    width: 40px;
    height: 40px;
    border-radius: 4px;
    object-fit: cover;
    flex-shrink: 0;
  }

  .slider-product-card__details {
    overflow: hidden;
  }

  .slider-product-card__title {
    margin: 0;
    font-size: 1.4rem;
    font-weight: 700;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    line-height: 1.2;
    color:white;
    text-shadow: 0 1px 2px rgba(0,0,0,0.3);
  }

  .slider-product-card__price {
    margin: 4px 0 0;
    font-size: 1.3rem;
    font-weight: 600;
    opacity: 1;
    text-shadow: 0 1px 2px rgba(0,0,0,0.3);
  }

  .slider-product-card__wishlist {
    position: absolute;
    top: 15px;
    right: 15px;
    width: 35px;
    height: 35px;
    background: rgba(255, 255, 255, 0.8);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    border: none;
    cursor: pointer;
    z-index: 2;
    transition: background 0.2s;
  }

  .slider-product-card__wishlist.active svg {
    fill: #ff4d4d;
    stroke: #ff4d4d;
  }

  .slider-product-card__wishlist svg {
    width: 18px;
    height: 18px;
  }

  /* Quick View Modal Styles */
  .quick-view-modal {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0,0,0,0.5);
    z-index: 1000;
    align-items: center;
    justify-content: center;
    padding: 20px;
  }

  .quick-view-modal[open] {
    display: flex;
  }

  .quick-view-modal__content {
    background: #fff;
    width: 100%;
    max-width: 900px;
    border-radius: 12px;
    position: relative;
    display: flex;
    flex-direction: row;
    overflow: hidden;
    max-height: 90vh;
  }

  @media screen and (max-width: 749px) {
    .quick-view-modal__content {
      flex-direction: column;
      overflow-y: auto;
      width: 95%;
      max-height: 85vh;
    }
  }

  .quick-view-modal__media {
    width: 50%;
    background: #f3f3f3;
  }

  @media screen and (max-width: 749px) {
    .quick-view-modal__media {
      display: none;
    }
    .quick-view-modal__info {
      width: 100% !important;
      padding: 20px !important;
    }
  }

  .quick-view-modal__media .swiper {
    width: 100%;
    height: 100%;
  }

  .quick-view-modal__info {
    width: 50%;
    padding: 30px;
    display: flex;
    flex-direction: column;
    gap: 15px;
    overflow-y: auto;
  }

  .quick-view-modal__close {
    position: absolute;
    top: 15px;
    right: 15px;
    z-index: 10;
    background: #fff;
    border: none;
    width: 30px;
    height: 30px;
    border-radius: 50%;
    cursor: pointer;
    box-shadow: 0 2px 5px rgba(0,0,0,0.1);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .quick-view-modal .product__title {
    font-family: var(--font-heading-family);
    font-size: 2.2rem;
    margin: 0;
  }

  .quick-view-modal .price {
    font-size: 1.8rem;
    font-weight: 600;
  }

  .quick-view-modal .btn-group {
    display: flex;
    gap: 10px;
    margin-top: 10px;
  }

  .quick-view-modal .add-to-cart {
    flex: 1;
    background: #000;
    color: #fff;
    border: none;
    padding: 12px;
    border-radius: 4px;
    font-weight: 600;
    cursor: pointer;
  }

  .quick-view-modal .view-details {
    display: block;
    text-decoration: underline;
    font-size: 1.4rem;
    color: #666;
  }

  .quick-view-modal .secondary-btn {
    width: 45px;
    height: 45px;
    border-radius: 50%;
    border: 1px solid #e0e0e0;
    background: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.2s;
    flex-shrink: 0;
  }

  .quick-view-modal .secondary-btn:hover {
    background: #f5f5f5;
    transform: scale(1.05);
  }

  .quick-view-modal .secondary-btn svg {
    width: 20px;
    height: 20px;
  }

  .quick-view-modal .secondary-btn.active svg {
    fill: #ff4d4d;
    stroke: #ff4d4d;
  }

  /* Swiper Navigation Customization */
  .featured-collection-slider .swiper-button-next,
  .featured-collection-slider .swiper-button-prev {
    background: white;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    box-shadow: 0 4px 10px rgba(0,0,0,0.15);
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    display: flex !important;
    align-items: center;
    justify-content: center;
  }

  .featured-collection-slider .swiper-button-next {
    right: 10px;
  }

  .featured-collection-slider .swiper-button-prev {
    left: 10px;
  }

  .featured-collection-slider .swiper-pagination {
    bottom: 5px !important;
    z-index: 10;
  }

  .featured-collection-slider .swiper-button-next::after,
  .featured-collection-slider .swiper-button-prev::after {
    font-size: 1.8rem;
    color: black;
    font-weight: bold;
  }

  .title-wrapper--view-all-heading {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 20px;
    margin-bottom: 3rem;
  }

  @media screen and (max-width: 749px) {
    .title-wrapper--view-all-heading {
      gap: 10px;
    }
  }



  .title-wrapper--view-all-heading[style*="text-align: right"] {
    flex-direction: row-reverse;
  }

  .title-wrapper--view-all-heading .button {
    margin-top: 0;
    flex-shrink: 0;
    min-width: fit-content;
    white-space: nowrap;
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient isolate">
  <div class="section-{{ section.id }}-padding page-width">
    
    <div class="collection__title title-wrapper title-wrapper--no-top-margin{% if section.settings.show_view_all and section.settings.view_all_position == 'heading' %} title-wrapper--view-all-heading{% endif %}" style="text-align: {{ section.settings.heading_alignment }};">
      {%- if section.settings.title != blank -%}
        <h2 class="title inline-richtext {{ section.settings.heading_size }}">
          {{ section.settings.title }}
        </h2>
      {%- endif -%}

      {%- if section.settings.show_view_all and section.settings.view_all_position == 'heading' -%}
        <a href="{{ section.settings.collection.url | default: '#' }}" class="button">
          {{ section.settings.view_all_text }}
        </a>
      {%- endif -%}
    </div>

    <div class="featured-collection-slider" id="Slider-{{ section.id }}">
      <div class="swiper">
        <div class="swiper-wrapper">
          {%- for product in section.settings.collection.products limit: section.settings.products_to_show -%}
            <div class="swiper-slide">
              <div class="slider-product-card" data-handle="{{ product.handle }}" onclick="openQuickView('{{ product.handle }}', '{{ section.id }}', this)">
                
                <div class="media">
                  {%- if section.settings.show_video -%}
                    {%- assign product_video = product.media | where: 'media_type', 'video' | first -%}
                    {%- if product_video -%}
                      {{ product_video | video_tag: autoplay: true, loop: true, muted: true, controls: false, playsinline: true }}
                    {%- else -%}
                      <img src="{{ product.featured_media | image_url: width: 600 }}" alt="{{ product.title | escape }}" loading="lazy">
                    {%- endif -%}
                  {%- else -%}
                    <img src="{{ product.featured_media | image_url: width: 600 }}" alt="{{ product.title | escape }}" loading="lazy">
                  {%- endif -%}
                </div>

                <div class="slider-product-card__info-overlay">
                  
                  <div class="slider-product-card__details">
                    <h3 class="slider-product-card__title">{{ product.title }}</h3>
                    <p class="slider-product-card__price">{{ product.price | money_without_trailing_zeros }}</p>
                  </div>
                </div>
              </div>
            </div>
          {%- else -%}
             {%- for i in (1..4) -%}
                <div class="swiper-slide">
                    <div class="slider-product-card">
                         <div class="media">
                            {{ 'product-' | append: i | placeholder_svg_tag: 'placeholder-svg' }}
                         </div>
                         <div class="slider-product-card__info-overlay">
                            <div class="slider-product-card__details">
                                <h3 class="slider-product-card__title">Onboarding Product</h3>
                                <p class="slider-product-card__price">$19.99</p>
                            </div>
                         </div>
                    </div>
                </div>
             {%- endfor -%}
          {%- endfor -%}
        </div>

      </div>
      
      {%- if section.settings.show_pagination -%}
        <div class="swiper-pagination"></div>
      {%- endif -%}

      {%- if section.settings.show_arrows -%}
        <div class="swiper-button-prev"></div>
        <div class="swiper-button-next"></div>
      {%- endif -%}
    </div>

      {%- if section.settings.show_view_all and section.settings.view_all_position == 'bottom' -%}
        <div class="center" style="margin-top: 30px;">
          <a href="{{ section.settings.collection.url | default: '#' }}" class="button">
            {{ section.settings.view_all_text }}
          </a>
        </div>
      {%- endif -%}
    </div>
  </div>
</div>

<!-- Quick View Modal -->
<div id="QuickView-{{ section.id }}" class="quick-view-modal">
  <div class="quick-view-modal__content">
    <button class="quick-view-modal__close" onclick="closeQuickView('{{ section.id }}')">
      {{- 'icon-close.svg' | inline_asset_content -}}
    </button>
    <div class="quick-view-modal__media">
       <div class="swiper swiper-modal">
          <div class="swiper-wrapper" id="ModalMediaWrapper-{{ section.id }}">
             <!-- Images injected here -->
          </div>
          <div class="swiper-pagination"></div>
       </div>
    </div>
    <div class="quick-view-modal__info" id="ModalInfo-{{ section.id }}">
       <!-- Info injected here -->
    </div>
  </div>
</div>

<div id="WishlistIconTemplate-{{ section.id }}" style="display:none;">
  {{- 'icon-heart.svg' | inline_asset_content -}}
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const swiperConfig = {
      freeMode: true,
      slidesPerView: {{ section.settings.columns_mobile }},
      spaceBetween: 20,
      loop: false,
      breakpoints: {
        750: {
          slidesPerView: {{ section.settings.columns_tablet | default: 3 }},
        },
        990: {
          slidesPerView: {{ section.settings.columns_desktop }},
        }
      }
    };

    {% if section.settings.show_pagination %}
      swiperConfig.pagination = {
        el: '#Slider-{{ section.id }} .swiper-pagination',
        clickable: true,
      };
    {% endif %}

    {% if section.settings.show_arrows %}
      swiperConfig.navigation = {
        nextEl: '#Slider-{{ section.id }} .swiper-button-next',
        prevEl: '#Slider-{{ section.id }} .swiper-button-prev',
      };
    {% endif %}

    new Swiper('#Slider-{{ section.id }} .swiper', swiperConfig);

    // Load wishlist state
    document.querySelectorAll('.slider-product-card__wishlist').forEach(btn => {
      const id = btn.getAttribute('onclick').match(/'([^']+)'/)[1];
      if (localStorage.getItem('wishlist_' + id)) {
        btn.classList.add('active');
      }
    });
  });

  function closeQuickView(sectionId) {
    const modal = document.getElementById('QuickView-' + sectionId);
    if (modal) {
      modal.removeAttribute('open');
    }
  }

  // Close modal on background click
  window.addEventListener('click', function(e) {
    if (e.target.classList.contains('quick-view-modal')) {
      e.target.removeAttribute('open');
    }
  });

  function toggleWishlist(e, id) {
    e.stopPropagation();
    const btn = e.currentTarget;
    if (btn.classList.contains('active')) {
      btn.classList.remove('active');
      localStorage.removeItem('wishlist_' + id);
    } else {
      btn.classList.add('active');
      localStorage.setItem('wishlist_' + id, 'true');
    }
  }

  function openQuickView(handle, sectionId, element) {
    const modal = document.getElementById('QuickView-' + sectionId);
    if (!modal) return;
    
    const mediaWrapper = document.getElementById('ModalMediaWrapper-' + sectionId);
    const infoWrapper = document.getElementById('ModalInfo-' + sectionId);

    // Get immediate data from the clicked card
    const initialTitle = element.querySelector('.slider-product-card__title')?.innerText || '';
    const initialImage = element.querySelector('img')?.src || '';
    const initialVideo = element.querySelector('video')?.src || '';

    modal.setAttribute('open', '');
    
    // Show immediate content
    if (initialVideo) {
      mediaWrapper.innerHTML = `
        <div class="swiper-slide">
          <video src="${initialVideo}" autoplay muted loop playsinline style="width:100%; height:100%; object-fit:cover;"></video>
        </div>`;
    } else if (initialImage) {
      mediaWrapper.innerHTML = `
        <div class="swiper-slide">
          <img src="${initialImage}" style="width:100%; height:100%; object-fit:cover;">
        </div>`;
    } else {
      mediaWrapper.innerHTML = '<div class="center" style="padding: 100px;">Loading...</div>';
    }

    infoWrapper.innerHTML = `
      <h2 class="product__title">${initialTitle}</h2>
      <div class="center" style="padding: 20px;">Loading details...</div>
    `;

    fetch('/products/' + handle + '.js')
      .then(res => res.json())
      .then(product => {
        // Clear previous media and add all media from API
        mediaWrapper.innerHTML = '';
        
        // Sort media to put videos first if any
        const sortedMedia = [...product.media].sort((a, b) => {
          if (a.media_type === 'video' && b.media_type !== 'video') return -1;
          if (a.media_type !== 'video' && b.media_type === 'video') return 1;
          return 0;
        });

        sortedMedia.forEach(m => {
          const slide = document.createElement('div');
          slide.className = 'swiper-slide';
          if (m.media_type === 'image') {
            slide.innerHTML = `<img src="${m.src}" style="width:100%; height:100%; object-fit:cover;">`;
          } else if (m.media_type === 'video') {
             // Use the first mp4 variant if available
             const videoVariant = m.variants ? m.variants.find(v => v.url.includes('.mp4')) : null;
             const videoUrl = videoVariant ? videoVariant.url : (m.src || '');
             if (videoUrl) {
               slide.innerHTML = `<video src="${videoUrl}" autoplay muted loop playsinline style="width:100%; height:100%; object-fit:cover;"></video>`;
             }
          }
          if (slide.innerHTML) mediaWrapper.appendChild(slide);
        });

        // Detailed Content
        const priceFormatted = (product.price / 100).toLocaleString('en-IN', {
          style: 'currency',
          currency: 'INR',
          maximumFractionDigits: 0
        });

        const isWishlisted = localStorage.getItem('wishlist_' + product.id);
        const activeClass = isWishlisted ? 'active' : '';
        const heartIcon = document.getElementById('WishlistIconTemplate-{{ section.id }}').innerHTML;

        // Thumbnails grid (show images after the featured one)
        const otherImages = product.media.filter(m => m.media_type === 'image').slice(1, 3);
        const thumbnailsHtml = otherImages.map(m => `
          <img src="${m.src}" style="width: calc(50% - 10px); aspect-ratio: 3/4; object-fit: cover; border-radius: 8px; border: 1px solid #eee;">
        `).join('');

        infoWrapper.innerHTML = `
          <div class="quick-view-gallery" style="display: flex; gap: 10px; margin-bottom: 20px;">
            ${thumbnailsHtml}
          </div>
          <h2 class="product__title" style="text-transform: uppercase; font-size: 1.8rem; letter-spacing: 0.5px;">${product.title}</h2>
          <div class="reviews-placeholder" style="color: #ffcc00; font-size: 1.6rem; margin-bottom: 5px;">
            ★★★★★ <span style="color: #666; font-size: 1.4rem;">2 reviews</span>
          </div>
          <div class="price" style="margin-bottom: 15px; font-size: 2.22rem;">${priceFormatted}</div>
          <div class="description" style="font-size: 1.4rem; color: #666; line-height: 1.6; margin-bottom: 20px;">${product.description ? product.description.replace(/<[^>]*>?/gm, '').substring(0, 150) + '...' : ''}</div>
          <div class="btn-group" style="margin-top: 20px; display: flex; align-items: center; gap: 8px; padding-top: 15px; border-top: 1px solid #f0f0f0;">
            <button class="add-to-cart" onclick="addToCart(${product.variants[0].id}, '${sectionId}')" style="background: #000; color: #fff; border: none; height: 45px; padding: 0 15px; border-radius: 6px; font-weight: 600; cursor: pointer; flex: 2; font-size: 1.3rem;">Add to cart</button>
            <button class="secondary-btn ${activeClass}" onclick="toggleWishlist(event, '${product.id}')" style="flex: 0 0 45px;">
               ${heartIcon}
            </button>
          </div>
          <a href="${product.url}" class="view-details" style="display: block; margin-top: 15px; font-weight: 600; color: #000; font-size: 1.3rem;">View details >></a>
        `;

        // Initialize modal swiper after content is injected
        setTimeout(() => {
          if (window.modalSwiper) window.modalSwiper.destroy();
          window.modalSwiper = new Swiper('#QuickView-' + sectionId + ' .swiper-modal', {
            freeMode: true,
            loop: product.media.length > 1,
            pagination: { 
              el: '#QuickView-' + sectionId + ' .swiper-pagination',
              clickable: true
            }
          });
        }, 100);
      })
      .catch(error => {
        infoWrapper.innerHTML = '<div class="center" style="padding: 50px;">Error loading product.</div>';
      });
  }

  function addToCart(variantId, sectionId) {
    const btn = document.querySelector('.add-to-cart');
    btn.innerHTML = 'Adding...';
    btn.disabled = true;

    let formData = {
     'items': [{
      'id': variantId,
      'quantity': 1
      }]
    };

    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(formData)
    })
    .then(res => res.json())
    .then(data => {
      // Refresh Dawn's cart components
      if (document.querySelector('cart-drawer')) {
          // Dawn 11+ uses publish/subscribe for cart updates
          if (window.publish) {
             publish(PUB_SUB_EVENTS.cartUpdate, {source: 'product-form'});
          }
          // Fallback if not using pubsub
          fetch('/?section_id=cart-drawer')
            .then(res => res.text())
            .then(html => {
              const inner = new DOMParser().parseFromString(html, 'text/html').querySelector('#CartDrawer');
              if (inner) document.querySelector('#CartDrawer').innerHTML = inner.innerHTML;
              document.querySelector('cart-drawer').classList.add('active');
            });
      }
      btn.innerHTML = 'Added!';
      setTimeout(() => {
        closeQuickView(sectionId);
        btn.innerHTML = 'Add to cart';
        btn.disabled = false;
      }, 500);
    })
    .catch(err => {
       console.error('Error adding to cart:', err);
       btn.disabled = false;
       btn.innerHTML = 'Add to cart';
    });
  }
</script>

{% schema %}
{
  "name": "Collection Slider",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "Select Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 20,
      "step": 1,
      "default": 8,
      "label": "Number of products to show"
    },
    {
      "type": "header",
      "content": "General Settings"
    },
    {
      "type": "inline_richtext",
      "id": "title",
      "default": "Featured Products",
      "label": "Heading"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" }
      ],
      "default": "h1",
      "label": "Heading size"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center",
      "label": "Heading alignment"
    },
    {
      "type": "checkbox",
      "id": "show_video",
      "default": false,
      "label": "Show video instead of image (if available)"
    },
    {
      "type": "header",
      "content": "Slider Settings"
    },
    {
      "type": "checkbox",
      "id": "show_pagination",
      "default": true,
      "label": "Show pagination dots"
    },
    {
      "type": "checkbox",
      "id": "show_arrows",
      "default": true,
      "label": "Show navigation arrows"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 1,
      "max": 5,
      "step": 1,
      "default": 3,
      "label": "Slides per view (Desktop)"
    },
    {
        "type": "range",
        "id": "columns_tablet",
        "min": 1,
        "max": 4,
        "step": 1,
        "default": 2,
        "label": "Slides per view (Tablet)"
    },
    {
      "type": "range",
      "id": "columns_mobile",
      "min": 1,
      "max": 3,
      "step": 0.1,
      "default": 1.2,

{% comment %}
  Renders cart drawer

  Usage:
  {% render 'cart-drawer' %}
{% endcomment %}

{{ 'quantity-popover.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'custom-cart-drawer.css' | asset_url | stylesheet_tag }}

<script src="{{ 'cart.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'quantity-popover.js' | asset_url }}" defer="defer"></script>

<style>
  .drawer {
    visibility: hidden;
  }
</style>

<cart-drawer class="drawer{% if cart == empty %} is-empty{% endif %}">
  <div id="CartDrawer" class="cart-drawer">
    <div id="CartDrawer-Overlay" class="cart-drawer__overlay"></div>
    <div
      class="drawer__inner gradient color-{{ settings.cart_color_scheme }}"
      role="dialog"
      aria-modal="true"
      aria-label="{{ 'sections.cart.title' | t }}"
      tabindex="-1"
    >
      <div class="drawer__header">
        <h2 class="drawer__heading">Shopping Cart ({{ cart.item_count }})</h2>
        <button
          class="drawer__close"
          type="button"
          onclick="this.closest('cart-drawer').close()"
          aria-label="{{ 'accessibility.close' | t }}"
        >
          <span class="svg-wrapper">
            {{- 'icon-close.svg' | inline_asset_content -}}
          </span>
        </button>
      </div>

      {%- if settings.show_free_shipping_progress_bar -%}
        {%- liquid
          assign free_shipping_threshold = settings.free_shipping_threshold | times: 100
          assign cart_total = cart.total_price
          assign remaining_amount = free_shipping_threshold | minus: cart_total
          assign progress_percent = cart_total | times: 100 | divided_by: free_shipping_threshold
          if progress_percent > 100
            assign progress_percent = 100
          endif
        -%}
        <div class="cart-drawer-shipping-bar" data-threshold="{{ free_shipping_threshold }}">
          <div class="cart-drawer-shipping-bar__message">
            {%- if remaining_amount > 0 -%}
              {%- assign amount = remaining_amount | money -%}
              {{ settings.free_shipping_progress_message | replace: '[amount]', amount }}
            {%- else -%}
              {{ settings.free_shipping_success_message }}
            {%- endif -%}
          </div>
          <div class="cart-drawer-shipping-bar__progress">
            <div class="cart-drawer-shipping-bar__progress-inner" style="width: {{ progress_percent }}%;">
              <span class="cart-drawer-shipping-bar__icon">
                {{- 'icon-truck.svg' | inline_asset_content -}}
              </span>
            </div>
          </div>
        </div>
      {%- endif -%}

      {%- if cart == empty -%}
        <div class="drawer__inner-empty">
          <div class="cart-drawer__empty-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="120" height="120" viewBox="0 0 100 100" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M25 40 L75 40 L68 85 L32 85 Z" fill="none" stroke="#ccc" stroke-width="2"/>
              <path d="M35 40 L45 20 M65 40 L55 20" stroke="#ccc" stroke-width="2"/>
              <circle cx="45" cy="55" r="1.5" fill="#aaa"/>
              <circle cx="55" cy="55" r="1.5" fill="#aaa"/>
              <path d="M47 65 Q50 62 53 65" stroke="#aaa" stroke-width="1.5" fill="none"/>
            </svg>
          </div>
          <h2 class="cart__empty-text">Your cart is currently empty!</h2>
          <p class="cart-drawer__empty-subtext">You may check out all the available products and buy some in the shop.</p>
          <a href="{{ routes.all_products_collection_url }}" class="cart-drawer__continue-btn">
            Continue Shopping
          </a>
        </div>
      {%- endif -%}

      <cart-drawer-items
        {% if cart == empty %}
          class=" is-empty hidden"
        {% endif %}
      >
        <form
          action="{{ routes.cart_url }}"
          id="CartDrawer-Form"
          class="cart__contents cart-drawer__form"
          method="post"
        >
          <div id="CartDrawer-CartItems" class="drawer__contents js-contents" style="width: 100%;">
            {%- if cart != empty -%}
              <div class="drawer__cart-items-wrapper">
                {%- for item in cart.items -%}
                  <div id="CartDrawer-Item-{{ item.index | plus: 1 }}" class="cart-item">
                    <div class="cart-item__media">
                      {% if item.image %}
                        <a href="{{ item.url }}">
                          <img
                            class="cart-item__image"
                            src="{{ item.image | image_url: width: 300 }}"
                            alt="{{ item.image.alt | escape }}"
                            loading="lazy"
                            width="100"
                            height="{{ 100 | divided_by: item.image.aspect_ratio | ceil }}"
                          >
                        </a>
                      {% endif %}
                    </div>

                    <div class="cart-item__details">
                      <a href="{{ item.url }}" class="cart-item__name">{{ item.product.title | escape }}</a>
                      <div class="cart-item__price">{{ item.original_line_price | money }}</div>

                      <div class="cart-item__bottom">
                        <quantity-popover>
                          <div class="cart-item__quantity-wrapper quantity-popover-wrapper">
                            <quantity-input class="quantity cart-quantity">
                              <button class="quantity__button" name="minus" type="button">
                                <span class="svg-wrapper">
                                  {{- 'icon-minus.svg' | inline_asset_content -}}
                                </span>
                              </button>
                              <input
                                class="quantity__input"
                                type="number"
                                data-quantity-variant-id="{{ item.variant.id }}"
                                name="updates[]"
                                value="{{ item.quantity }}"
                                data-cart-quantity="{{ cart | item_count_for_variant: item.variant.id }}"
                                min="0"
                                data-min="{{ item.variant.quantity_rule.min }}"
                                id="Drawer-quantity-{{ item.index | plus: 1 }}"
                                data-index="{{ item.index | plus: 1 }}"
                              >
                              <button class="quantity__button" name="plus" type="button">
                                <span class="svg-wrapper">
                                  {{- 'icon-plus.svg' | inline_asset_content -}}
                                </span>
                              </button>
                            </quantity-input>
                          </div>
                        </quantity-popover>

                        <cart-remove-button
                          id="CartDrawer-Remove-{{ item.index | plus: 1 }}"
                          data-index="{{ item.index | plus: 1 }}"
                        >
                          <a
                            href="{{ item.url_to_remove }}"
                            class="cart-remove-button"
                            aria-label="{{ 'sections.cart.remove_title' | t: title: item.title | escape }}"
                          >
                            <span class="svg-wrapper">
                              {{- 'icon-remove.svg' | inline_asset_content -}}
                            </span>
                          </a>
                        </cart-remove-button>
                      </div>
                    </div>
                  </div>
                {%- endfor -%}
              </div>
            {%- endif -%}
            <p class="visually-hidden" id="CartDrawer-LiveRegionText" aria-live="polite" role="status"></p>
            <p class="visually-hidden" id="CartDrawer-LineItemStatus" aria-live="polite" aria-hidden="true" role="status">
              {{ 'accessibility.loading' | t }}
            </p>
            <div id="CartDrawer-CartErrors" role="alert"></div>
          </div>
        </form>
      </cart-drawer-items>

      {%- if settings.cart_drawer_collection != blank -%}
        {%- assign upsell_count = 0 -%}
        {%- for p in collections[settings.cart_drawer_collection.handle].products limit: 3 -%}
          {%- assign upsell_count = forloop.length -%}
        {%- endfor -%}
        <div class="cart-drawer-upsell-container" style="padding: 0 2.5rem;">
          <h3 class="cart-drawer__upsell-title">You may also like...</h3>
          <div class="cart-drawer__upsell-wrapper">
             {%- for upsell_product in collections[settings.cart_drawer_collection.handle].products limit: 3 -%}
              <div class="cart-drawer__upsell-item">
                <img src="{{ upsell_product.featured_image | image_url: width: 200 }}" class="upsell-item__image" alt="{{ upsell_product.title }}">
                <div class="upsell-item__details">
                  <span class="upsell-item__title">{{ upsell_product.title }}</span>
                  <span class="upsell-item__price">{{ upsell_product.price | money }}</span>
                  <a href="{{ upsell_product.url }}" class="upsell-item__add">Add To Cart</a>
                </div>
              </div>
            {%- endfor -%}
          </div>
          <div class="cart-drawer__upsell-dots">
            {%- for i in (1..upsell_count) -%}
              <span class="upsell-dot{% if forloop.first %} active{% endif %}"></span>
            {%- endfor -%}
          </div>
        </div>
      {%- endif -%}

      <div class="drawer__footer {% if cart == empty %}hidden{% endif %}">


        <div class="cart-drawer__footer-content cart-drawer__footer">
          <div class="cart-drawer__subtotal">
            <span class="cart-drawer__subtotal-label">Subtotal</span>
            <span class="cart-drawer__subtotal-value">{{ cart.total_price | money }}</span>
          </div>

          <div class="cart-drawer__terms">
            <input type="checkbox" id="cart-drawer-terms">
            <label for="cart-drawer-terms">I agree with <strong>Terms & Conditions</strong></label>
          </div>

          <div class="cart-drawer__buttons">
            <a href="{{ routes.cart_url }}" class="btn-view-cart">View Cart</a>
            <button type="submit" form="CartDrawer-Form" name="checkout" class="btn-checkout">Checkout</button>
          </div>
        </div>
      </div>
    </div>
  </div>
</cart-drawer>
